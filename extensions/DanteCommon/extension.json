{
  "name":     "DanteCommon",
  "version":  "1.0", 
  "author":   ["Clemens H. Cap"],
  "url":      "",
  "description": "Provides common functionality for Dante extensions",
  "license-name": "GPL-2.0-or-later",
  "type": "other",
  "AutoloadClasses": {
    "DanteSpecialPage":     "DanteSpecialPages.php",
    "ServiceExecutor":      "ServiceExecutor.php",
    "InfoExtractor":        "InfoExtractor.php",
    "OperatingMode":        "OperatingMode.php"
  },
  "ResourceModules": {
    "ext.DantePresentations": {
      "localBasePath":       "modules",
      "remoteExtPath":       "DantePresentations/modules",
      "packageFiles":        ["ext.DantePresentations.js", "audio.js", "languages.js"],
      "styles":              ["dantePresentations.css"]
    },
    "ext.DantePresentations.styles": {
      "styles": ["special.css", "tags.css", "toc.css"],
      "position": "top"
    }
  },
   "SpecialPages": {
     "DanteDevelopment": { "class": "OperatingMode"}
  },
   "MessagesDirs":           { "DanteCommon": ["i18n"] },
   "ExtensionMessagesFiles": { 
      "DanteCommonAlias":  "DanteCommon.alias.php"
    },
   "GroupPermissions": {
    "sysop": {
      "developDante": true
    }
  },
  "manifest_version": 2
} 
